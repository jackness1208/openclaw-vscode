{
    "name": "openclaw-vscode",
    "private": true,
    "scripts": {
        "prepare": "tsc -b && yarn tsref && lerna run prepare",
        "tsref": "node scripts/typescript-references.js",
        "watch": "concurrently -k -n TSC,WEBPACK -c yellow,blue \"tsc -b -w\" \"lerna run watch --parallel\"",
        "clean": "lerna run clean",
        "vsce:package": "lerna run vsce:package"
    },
    "devDependencies": {
        "concurrently": "^9.1.2",
        "copy-webpack-plugin": "^14.0.0",
        "eslint": "^8.43.0",
        "lerna": "^8.0.0",
        "ovsx": "0.9.1",
        "prettier": "^3.0.2",
        "source-map-loader": "^5.0.0",
        "webpack": "^5.20.2",
        "webpack-cli": "^4.5.0"
    },
    "workspaces": [
        "openclaw-vscode-common",
        "openclaw-vscode-webviews",
        "openclaw-vscode-extension"
    ]
}
