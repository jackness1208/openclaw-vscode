// A launch configuration that compiles the extension and then opens it inside a new window
{
    "version": "0.1.0",
    "configurations": [
        {
            "name": "Launch Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/openclaw-vscode-extension"
            ],
            "outFiles": [
                "${workspaceFolder}/openclaw-vscode-extension/pack/*.js",
                "${workspaceFolder}/openclaw-vscode-extension/lib/**/*.js"
            ],
            "sourceMaps": true
        }
    ]
}
