{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": ["--extensionDevelopmentPath=${workspaceFolder}/openclaw-vscode-extension"],
            "outFiles": [
                "${workspaceFolder}/openclaw-vscode-extension/pack/*.js",
                "${workspaceFolder}/openclaw-vscode-extension/lib/**/*.js"
            ],
            "sourceMaps": true,
            "preLaunchTask": "npm: prepare"
        },
        {
            "name": "Attach to Extension Host",
            "type": "extensionHost",
            "request": "attach",
            "port": 5858
        }
    ]
}
